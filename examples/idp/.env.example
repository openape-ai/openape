# Required
NUXT_OPENAPE_MANAGEMENT_TOKEN=change-me-random-token
NUXT_OPENAPE_SESSION_SECRET=change-me-at-least-32-characters-long

# Admin (comma-separated emails)
NUXT_OPENAPE_ADMIN_EMAILS=admin@example.com

# WebAuthn (defaults work for localhost)
# NUXT_OPENAPE_RP_ID=id.example.com
# NUXT_OPENAPE_RP_ORIGIN=https://id.example.com
# NUXT_OPENAPE_ISSUER=https://id.example.com

# Storage prefix (auto-derived from issuer hostname if empty)
# NUXT_OPENAPE_STORAGE_PREFIX=

# S3 Storage (leave empty for local filesystem)
# NUXT_OPENAPE_STORAGE_DRIVER=s3
# NUXT_OPENAPE_S3_ACCESS_KEY=
# NUXT_OPENAPE_S3_SECRET_KEY=
# NUXT_OPENAPE_S3_BUCKET=
# NUXT_OPENAPE_S3_ENDPOINT=
# NUXT_OPENAPE_S3_REGION=
# NUXT_OPENAPE_S3_PREFIX=openape-idp/
