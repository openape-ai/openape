# LLM gateway (llms.openape.ai) secrets — chatty-only, never commit the real .env.
# Lives on chatty at /home/openape/prod-llms/.env. Copy this file, fill the values.

# Session secret for the llm-auth SP (DDISA token verification at the gateway).
LLMS_SESSION_SECRET=

# LiteLLM admin/master key. Fallback auth path; DDISA per-agent tokens are the
# primary auth. Required (compose pins it with ${LITELLM_MASTER_KEY:?}).
LITELLM_MASTER_KEY=

# Upstream key for the headwai sub-provider (self-hosted vLLM, default group).
HEADWAI_API_KEY=
