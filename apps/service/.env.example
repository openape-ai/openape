# Session & Auth
NUXT_OPENAPE_SESSION_SECRET=change-me-to-a-real-secret-at-least-32-chars
NUXT_OPENAPE_MANAGEMENT_TOKEN=

# Platform
NUXT_PLATFORM_ADMIN_EMAILS=admin@example.com

# S3 Storage (Exoscale SOS)
NUXT_S3_ACCESS_KEY=
NUXT_S3_SECRET_KEY=
NUXT_S3_BUCKET=openape-cloud
NUXT_S3_ENDPOINT=https://sos-de-fra-1.exo.io
NUXT_S3_REGION=de-fra-1

# Stripe
NUXT_STRIPE_SECRET_KEY=sk_test_...
NUXT_STRIPE_WEBHOOK_SECRET=whsec_...
NUXT_STRIPE_PRICE_USER_MONTHLY=price_...
NUXT_STRIPE_PRICE_AGENT_MONTHLY=price_...

# Vercel (for custom domains)
NUXT_VERCEL_API_TOKEN=
NUXT_VERCEL_PROJECT_ID=
NUXT_VERCEL_TEAM_ID=

# Public
NUXT_PUBLIC_DOMAIN=cloud.openape.at
