{
  "name": "openape-agent-mail",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --port 3003",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxi prepare && nuxt typecheck",
    "lint": "eslint .",
    "test": "nuxi prepare && vitest --config vitest.config.ts",
    "test:run": "nuxi prepare && vitest run --config vitest.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.90",
    "@libsql/client": "^0.14.0",
    "@nuxt/ui": "^4.4.0",
    "@openape/core": "workspace:*",
    "@openape/auth": "workspace:*",
    "@openape/nuxt-auth-sp": "workspace:*",
    "drizzle-orm": "^0.44.0",
    "nuxt": "^4.0.0",
    "resend": "^4.0.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "^0.30.0",
    "h3": "^1.15.5",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
