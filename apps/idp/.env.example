# Nitro maps NITRO_<KEY> env vars to runtimeConfig at runtime.
# Keys are converted from camelCase to UPPER_SNAKE_CASE.
NITRO_ISSUER=http://localhost:3000
NITRO_MANAGEMENT_TOKEN=
NITRO_SESSION_SECRET=change-me-to-a-secret-at-least-32-characters!
NITRO_ADMIN_EMAILS=admin@example.com
NITRO_TURSO_URL=file:local.db
NITRO_TURSO_AUTH_TOKEN=
