{
  "name": "@openape/proxy",
  "type": "module",
  "version": "0.3.1",
  "turbo": {
    "tags": [
      "publishable"
    ]
  },
  "description": "OpenApe agent HTTP gateway — forward proxy with grant-based access control",
  "author": "Patrick Hofmann",
  "license": "MIT",
  "bin": {
    "openape-proxy": "./dist/index.js"
  },
  "files": [
    "dist",
    "config.example.toml",
    "README.md"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@openape/core": "workspace:*",
    "@openape/grants": "workspace:*",
    "jose": "^5.9.0",
    "smol-toml": "^1.3.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/openape-ai/openape.git",
    "directory": "packages/proxy"
  },
  "engines": {
    "node": ">=22"
  }
}
