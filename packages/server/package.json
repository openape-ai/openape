{
  "name": "@openape/server",
  "type": "module",
  "version": "0.3.10",
  "description": "Programmatic DDISA IdP and SP server (h3)",
  "author": "Delta Mind GmbH",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./handlers": {
      "types": "./dist/handlers.d.ts",
      "import": "./dist/handlers.js",
      "require": "./dist/handlers.cjs"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --coverage --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@openape/auth": "workspace:*",
    "@openape/core": "workspace:*",
    "@openape/grants": "workspace:*",
    "h3": "^1.15.0",
    "jose": "^5.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-istanbul": "^2.1.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/openape-ai/openape.git",
    "directory": "packages/server"
  },
  "turbo": {
    "tags": [
      "publishable"
    ]
  }
}
