{
  "name": "@openape/browser",
  "type": "module",
  "version": "0.1.0",
  "description": "Grant-aware headless browser for OpenAPE — Playwright wrapper with route interception, grants, and delegation login",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:run": "vitest run"
  },
  "peerDependencies": {
    "playwright": "^1.50.0",
    "playwright-core": "^1.50.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    },
    "playwright-core": {
      "optional": true
    }
  },
  "dependencies": {
    "@openape/core": "workspace:*"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.12.0",
    "@types/node": "^25.3.5",
    "eslint": "^9.22.0",
    "playwright-core": "^1.50.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "@openape/core": "link:../core"
    }
  }
}
