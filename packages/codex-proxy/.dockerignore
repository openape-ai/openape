# Keep the Docker build context (apps/openape-llm/Dockerfile builds from this
# package dir) minimal: only package.json + tsconfig + tsup.config + src/ are
# needed. Excluding node_modules/dist/.turbo also avoids macOS AppleDouble
# (._*) files sneaking into the image.
node_modules
dist
.turbo
test
*.tsbuildinfo
._*
.DS_Store
