    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/openape-ai/openape.git",
    "directory": "packages/core"
  }
