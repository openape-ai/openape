{
  "name": "@openape/openclaw-plugin-grants",
  "type": "module",
  "version": "0.1.0",
  "description": "OpenClaw plugin for grant-based command execution with granular permissions",
  "license": "MIT",
  "author": "Patrick Hofmann <patrick@delta-mind.at>",
  "repository": {
    "type": "git",
    "url": "https://github.com/openape-ai/openape.git",
    "directory": "packages/openclaw-plugin-grants"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "adapters",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@openape/core": "workspace:*",
    "@openape/grants": "workspace:*",
    "jose": "catalog:",
    "consola": "^3.4.2"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "tsup": "catalog:",
    "vitest": "catalog:",
    "eslint": "catalog:",
    "@antfu/eslint-config": "catalog:"
  },
  "engines": {
    "node": ">=22"
  },
  "openclaw": {
    "extensions": ["./dist/index.js"]
  },
  "publishConfig": {
    "access": "public"
  }
}
