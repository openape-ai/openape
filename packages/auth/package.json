{
  "name": "@openape/auth",
  "type": "module",
  "version": "0.12.0",
  "turbo": {
    "tags": [
      "publishable"
    ]
  },
  "description": "OpenApe authentication: IdP + SP OIDC protocol logic",
  "author": "Delta Mind GmbH",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
