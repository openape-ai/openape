#!/bin/bash
set -o pipefail
# Pre-push hook — local CI gate. This repo runs no server-side CI (off
# GitHub Actions/Blacksmith), so this hook IS the gate: it mirrors what
# .github/workflows/ci.yml used to run, before any code leaves the machine.
#
#   Bypass (emergency / WIP):  SKIP_HOOKS=1 git push
#   Auto-skipped under CI=…    (defensive — there is no CI runner anymore)

if [ -n "$CI" ]; then exit 0; fi
if [ "$SKIP_HOOKS" = "1" ]; then
  echo "[pre-push] SKIP_HOOKS=1 — skipping local CI gate"
  exit 0
fi

echo "[pre-push] Local CI gate — build, audit, lint, typecheck, test"

set -e

# 1. Build packages + modules (apps consume their dist for typecheck).
echo "[pre-push] → build packages + modules"
pnpm turbo run build --filter='./packages/*' --filter='./modules/*' --concurrency=4

# 2. Generate Nuxt types so typecheck sees them in module playgrounds + apps.
for mod in modules/nuxt-auth-idp modules/nuxt-auth-sp; do
  [ -d "$mod/playground" ] && (cd "$mod" && npx nuxi prepare playground) || true
done
for app in apps/openape-free-idp apps/openape-agent-proxy; do
  [ -f "$app/package.json" ] && (cd "$app" && npx nuxi prepare) || true
done

# 3. Security audit — production deps, high+ blocks the push.
echo "[pre-push] → audit (prod, high+)"
pnpm audit --prod --audit-level=high

# 4. Lint + typecheck + test across packages + modules + apps.
echo "[pre-push] → lint + typecheck + test"
pnpm turbo run lint typecheck test --filter='./packages/*' --filter='./modules/*' --filter='./apps/*' --concurrency=4

echo "[pre-push] ✓ all checks passed"
