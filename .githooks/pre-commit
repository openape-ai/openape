#!/bin/sh
# Pre-commit hook: ensure pnpm-lock.yaml stays in sync with package.json files
#
# If any package.json is staged, verify pnpm-lock.yaml is also staged.
# Uses a temp worktree of the staged state to run the check cleanly.

staged_package_jsons=$(git diff --cached --name-only --diff-filter=ACMR | grep 'package\.json$' || true)

if [ -z "$staged_package_jsons" ]; then
  exit 0
fi

echo "[pre-commit] package.json changes detected, verifying lockfile..."

# Check if pnpm-lock.yaml is also staged
lockfile_staged=$(git diff --cached --name-only | grep '^pnpm-lock.yaml$' || true)

if [ -z "$lockfile_staged" ]; then
  # pnpm-lock.yaml not staged — check if it needs to be
  # Create a temp dir with the staged state of all package.json files
  tmpdir=$(mktemp -d)
  trap 'rm -rf "$tmpdir"' EXIT

  # Export the staged tree to temp dir
  git checkout-index --prefix="$tmpdir/" -a 2>/dev/null

  # Run lockfile check in the staged state
  if ! (cd "$tmpdir" && pnpm install --lockfile-only 2>/dev/null); then
    echo ""
    echo "[pre-commit] ERROR: pnpm-lock.yaml is out of sync with staged package.json files."
    echo "  Run: pnpm install"
    echo "  Then stage: git add pnpm-lock.yaml"
    exit 1
  fi

  # Compare the generated lockfile with the staged one
  if ! diff -q "$tmpdir/pnpm-lock.yaml" pnpm-lock.yaml >/dev/null 2>&1; then
    echo ""
    echo "[pre-commit] pnpm-lock.yaml needs updating. Run:"
    echo "  pnpm install && git add pnpm-lock.yaml"
    exit 1
  fi
fi

echo "[pre-commit] lockfile OK"
