#!/bin/bash
set -o pipefail
# Pre-commit hook for OpenAPE monorepo
# 1. Lockfile sync check (only when package.json changes)
# 2. Lint + typecheck on affected packages (via turbo --affected)

# Skip in CI — these checks run in the CI workflow
if [ -n "$CI" ]; then
  exit 0
fi

# Skip with SKIP_HOOKS=1 for emergency commits
if [ "$SKIP_HOOKS" = "1" ]; then
  exit 0
fi

errors=0

# --- Lockfile sync ---
staged_package_jsons=$(git diff --cached --name-only --diff-filter=ACMR | grep 'package\.json$' || true)

if [ -n "$staged_package_jsons" ]; then
  echo "[pre-commit] package.json changes detected, verifying lockfile..."

  lockfile_staged=$(git diff --cached --name-only | grep '^pnpm-lock.yaml$' || true)

  if [ -z "$lockfile_staged" ]; then
    tmpdir=$(mktemp -d)
    trap 'rm -rf "$tmpdir"' EXIT

    git checkout-index --prefix="$tmpdir/" -a 2>/dev/null

    if ! (cd "$tmpdir" && pnpm install --lockfile-only 2>/dev/null); then
      echo "[pre-commit] ERROR: pnpm-lock.yaml is out of sync."
      echo "  Run: pnpm install && git add pnpm-lock.yaml"
      errors=1
    elif ! diff -q "$tmpdir/pnpm-lock.yaml" pnpm-lock.yaml >/dev/null 2>&1; then
      echo "[pre-commit] ERROR: pnpm-lock.yaml needs updating."
      echo "  Run: pnpm install && git add pnpm-lock.yaml"
      errors=1
    else
      echo "[pre-commit] lockfile OK"
    fi
  else
    echo "[pre-commit] lockfile staged, OK"
  fi
fi

# --- Lint + Typecheck (affected packages only) ---
staged_src=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|js|jsx|vue)$' || true)

if [ -n "$staged_src" ]; then
  echo "[pre-commit] Running lint on affected packages..."
  if ! pnpm turbo run lint --affected --concurrency=4 2>&1 | tail -5; then
    echo "[pre-commit] ERROR: lint failed"
    errors=1
  fi

  echo "[pre-commit] Running typecheck on affected packages..."
  if ! pnpm turbo run typecheck --affected --concurrency=4 2>&1 | tail -5; then
    echo "[pre-commit] ERROR: typecheck failed"
    errors=1
  fi
fi

if [ "$errors" -ne 0 ]; then
  echo ""
  echo "[pre-commit] BLOCKED — fix errors above before committing."
  echo "  Skip with: SKIP_HOOKS=1 git commit ..."
  exit 1
fi
