{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".output/**", ".vercel/output/**"],
      "cache": true
    },
    "nuxt-prepare": {
      "dependsOn": ["^build"],
      "outputs": [".nuxt/**"],
      "cache": true
    },
    "typecheck": {
      "dependsOn": ["^build", "nuxt-prepare"],
      "cache": true
    },
    "lint": {
      "cache": true
    },
    "test": {
      "dependsOn": ["^build", "nuxt-prepare"],
      "cache": true
    },
    "test:e2e": {
      "dependsOn": ["^build", "nuxt-prepare"],
      "cache": false
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    }
  }
}
