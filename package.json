{
  "name": "openape",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "dev": "turbo run dev",
    "graph": "node scripts/dependency-graph.mjs",
    "knip": "knip",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "node scripts/publish-chain.mjs",
    "release:dry": "node scripts/publish-chain.mjs --dry-run",
    "release:local": "node scripts/release-local.mjs",
    "deploy": "node scripts/deploy.mjs",
    "deploy:image": "node scripts/deploy-image.mjs",
    "deploy:gateway": "node scripts/deploy-gateway.mjs",
    "gateway:drift": "node scripts/gateway-drift.mjs",
    "sync:openclaw": "bash scripts/sync-openclaw-skills.sh",
    "seed:shapes": "tsx scripts/seed-shapes.ts",
    "prepare": "git config core.hooksPath .githooks || true",
    "deploy:docs-site": "node scripts/deploy-docs-site.mjs",
    "guides": "bash compose/demo/run.sh"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "catalog:",
    "@libsql/client": "^0.17.4",
    "@vitest/coverage-istanbul": "^4.1.9",
    "drizzle-orm": "^0.45.2",
    "eslint": "^9.39.4",
    "knip": "^6.23.0",
    "smol-toml": "^1.7.0",
    "tsx": "^4.22.4",
    "turbo": "^2.10.0"
  }
}
