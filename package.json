{
  "name": "@openape/auth",
  "type": "module",
  "version": "0.1.2",
  "description": "OpenApe authentication: IdP + SP OIDC protocol logic",
  "author": "Delta Mind GmbH",
  "license": "AGPL-3.0-or-later",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm pack --dry-run && npm publish --provenance --access public"
  },
  "peerDependencies": {
    "h3": "^1.13.0"
  },
  "peerDependenciesMeta": {
    "h3": {
      "optional": true
    }
  },
  "dependencies": {
    "@openape/core": "^0.1.2",
    "@simplewebauthn/server": "^11",
    "@simplewebauthn/types": "^11",
    "jose": "^5.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "h3": "^1.13.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "@antfu/eslint-config": "^7.6.1",
    "eslint": "^9.35.0",
    "@changesets/cli": "^2.29.7"
  },
  "engines": {
    "node": ">=22"
  }
}
