{
  "name": "@openape/nuxt-auth-sp",
  "type": "module",
  "version": "0.3.0",
  "description": "OpenAPE Service Provider Nuxt module — adds OIDC login via DNS-based IdP discovery",
  "author": "Delta Mind GmbH",
  "license": "AGPL-3.0-or-later",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./handlers": {
      "types": "./dist/runtime/server/handlers.d.ts",
      "import": "./dist/runtime/server/handlers.js"
    }
  },
  "main": "./dist/module.mjs",
  "types": "./dist/types.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "nuxt-module-build build",
    "dev": "nuxt-module-build build --stub",
    "prepare": "nuxi prepare playground",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm pack --dry-run && npm publish --provenance --access public"
  },
  "dependencies": {
    "@nuxt/kit": "^3.21.1",
    "@openape/auth": "^0.1.3",
    "@openape/core": "^0.1.2",
    "@openape/nuxt-auth-sp": "0.3.0",
    "defu": "^6.1.4"
  },
  "peerDependencies": {
    "nuxt": "^4.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "@changesets/cli": "^2.30.0",
    "@nuxt/module-builder": "^0.8.4",
    "@types/node": "^22.19.13",
    "eslint": "^9.39.3",
    "nuxt": "^4.3.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": ">=22"
  }
}
